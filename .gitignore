# ==============================================================================
# .gitignore for cooperative-mission-planner (public portfolio)
# ==============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ── Virtual environments ──────────────────────────────────────────────────────
Q_wingman/
venv/
.venv/
env/
.env/
.conda/

# ── Solver artifacts ──────────────────────────────────────────────────────────
*.pkl
*.pickle
*.json
!scenarios/*.json
*.lp
*.mps
*.sol

# ── Generated plots (only curated figures/ are committed) ─────────────────────
v6/plots/
v4/plots/
plots/
*.png
!figures/*.png

# ── LaTeX build artifacts ─────────────────────────────────────────────────────
*.aux
*.bbl
*.blg
*.log
*.out
*.toc
*.lof
*.lot
*.fls
*.fdb_latexmk
*.synctex.gz
*.synctex(busy)
*.run.xml
*.bcf
*.nav
*.snm
*.vrb

# ── PDFs (only explicitly selected ones are committed) ────────────────────────
*.pdf
!figures/*.pdf

# ── Large artifacts ───────────────────────────────────────────────────────────
*.h5
*.hdf5
*.npy
*.npz
*.csv
*.parquet
*.tar.gz
*.zip
*.rar

# ── Logs and temp files ───────────────────────────────────────────────────────
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.swp
*~

# ── Editor / IDE junk ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.settings/
*.code-workspace

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# ── Private / sensitive ───────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
credentials.*
secrets.*

# ── Claude Code / AI assistant ───────────────────────────────────────────────
.claude/
CLAUDE.md

# ── Sprint logs, experiment folders, private notes ────────────────────────────
sprint_*/
gurobi/
archive/
paper/
docs/private/
*.md.bak
MEMORY.md
memory/

# ── Raw experiment outputs ────────────────────────────────────────────────────
*_result.png
*_trajectory.png
*_telemetry*.png
*_dashboard*.png
weapon_combo*.json
coarse_solution*.json
